  {
    "id": "b7cb4d8e7e6a1015",
    "type": "function",
    "z": "b7cb4d8e7e6a1001",
    "name": "Normalizar pressao HX710B",
    "func": "let data = msg.payload;\n\nif (typeof data === \"string\") {\n    try {\n        data = JSON.parse(data);\n    } catch (error) {\n        msg.payload = {\n            error: \"invalid_pressure_json\",\n            raw_payload: data\n        };\n        return [msg, null, null, null];\n    }\n}\n\nif (!data || typeof data !== \"object\") {\n    msg.payload = {\n        error: \"invalid_pressure_payload\",\n        raw_payload: data\n    };\n    return [msg, null, null, null];\n}\n\nif (data.error) {\n    const errorMsg = {\n        payload: {\n            error: data.error,\n            timeouts: Number(data.timeouts || 0),\n            mode: Number(data.mode || 2)\n        },\n        topic: msg.topic\n    };\n    return [errorMsg, null, null, errorMsg];\n}\n\nconst pressureKpa = Number(data.pressure_kpa ?? data.pressure ?? 0);\nconst pressureMmhg = Number(data.pressure_mmhg ?? pressureKpa * 7.50062);\nconst raw = Number(data.raw ?? 0);\nconst net = Number(data.net ?? 0);\nconst timeouts = Number(data.timeouts ?? 0);\nconst mode = Number(data.mode ?? 2);\n\nconst normalized = {\n    pressure: pressureKpa,\n    pressure_kpa: pressureKpa,\n    pressure_mmhg: pressureMmhg,\n    raw,\n    net,\n    timeouts,\n    mode\n};\n\nreturn [\n    { payload: normalized, topic: msg.topic },\n    { payload: pressureKpa, topic: \"hand-rehab/esp32/pressure/kpa\" },\n    { payload: pressureMmhg, topic: \"hand-rehab/esp32/pressure/mmhg\" },\n    { payload: { raw, net, timeouts }, topic: \"hand-rehab/esp32/pressure/raw\" }\n];",
    "outputs": 4,
    "noerr": 0,
