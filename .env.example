POSTGRES_DB=rehab_game
POSTGRES_USER=rehab_user
POSTGRES_PASSWORD=rehab_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://rehab_user:rehab_password@postgres:5432/rehab_game

BACKEND_HOST=backend
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000

NODE_RED_PORT=1880
MQTT_PORT=1883
MQTT_HOST=node-red
NODE_RED_MQTT_BROKER=127.0.0.1
NODE_RED_CLIENT_ID=node-red-hand-rehab
DEFAULT_DEVICE_ID=esp32-001

FRONTEND_PORT=5173
VITE_BACKEND_API_URL=http://localhost:8000
VITE_NODE_RED_WS_URL=ws://localhost:1880/ws/realtime

# Firmware ESP32: copie os valores equivalentes para
# esp32-esp8266/hand-rehab/include/secrets.h.
# MQTT_HOST deve ser o IP LAN do computador rodando Docker, nunca "nodered".
WIFI_SSID=NOME_DA_REDE
WIFI_PASSWORD=SENHA_DA_REDE
FIRMWARE_MQTT_HOST=192.168.0.100
FIRMWARE_MQTT_PORT=1883
DEVICE_ID=esp32-001
